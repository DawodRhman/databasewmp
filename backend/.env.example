# ─── Backend Environment Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Only the BACKEND has database credentials. Frontend does NOT.
# ────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── CORS: Frontend URL(s) allowed to call this API ─────────────────────────
# Comma-separated list of frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://wmp.kwsc.gos.pk,http://localhost:3000

# ─── Network Validation (IP-level firewall) ──────────────────────────────────
# Comma-separated list of IPs/CIDRs allowed to reach this backend.
# Only the Frontend VM and internal services should be listed here.
# Leave empty to rely on CORS only (less secure).
ALLOWED_NETWORKS=10.0.1.1,10.0.1.0/24
TRUST_PROXY=true

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# ONLY the backend connects to the database. Frontend never has these.
# Point to your Database VM's IP/hostname.
DB_HOST=10.0.1.3
DB_PORT=5432
DB_NAME=warehouse
DB_USER=root
DB_PASSWORD="**Abc123"
DB_SSL=false
DB_POOL_MAX=20

# ─── JWT / Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth (optional) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email (Nodemailer) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@kwsc.gos.pk
SMTP_PASSWORD=your_email_password
SMTP_FROM=WMP <no-reply@kwsc.gos.pk>

# ─── File Uploads (stored on Database VM via NFS/shared mount) ───────────────
# Mount the Database VM's storage at this path so uploads are co-located with DB.
# e.g., NFS mount: mount 10.0.1.3:/data/uploads /mnt/wmp-uploads
# Or use a local path if backend and DB are on the same machine.
UPLOAD_DIR=/mnt/wmp-uploads
MAX_FILE_SIZE=52428800
