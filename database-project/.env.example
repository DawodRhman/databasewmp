# ─── Database VM Environment ─────────────────────────────────────────────────
# This VM hosts PostgreSQL and the shared uploads storage.
# Only the Backend VM connects here — Frontend has NO access.
# ────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection (runs locally on this VM)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=warehouse
DB_USER=root
DB_PASSWORD=your_password_here
DB_SSL=false

# ─── Shared Upload Storage ──────────────────────────────────────────────────
# The Backend VM mounts this directory via NFS to store/serve uploads.
# Export this path over NFS so the backend can read/write files here.
# e.g., in /etc/exports: /data/uploads 10.0.1.2(rw,sync,no_subtree_check)
UPLOADS_STORAGE_DIR=/data/uploads

# ─── Backup Config ──────────────────────────────────────────────────────────
BACKUP_DIR=/var/backups/wmp
BACKUP_RETENTION_DAYS=30
